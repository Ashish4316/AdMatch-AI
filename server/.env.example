# ============================================================
# AdMatch AI — Server Environment Variables
# Copy this file to .env and fill in your actual values.
# ============================================================

# ----- App -----
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ----- JWT -----
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ----- PostgreSQL Database (Supabase) -----
DB_HOST=db.mcchaicxwdcfnbbisdmn.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_password

# Or use connection string
# DATABASE_URL=postgresql://postgres:your_supabase_password@db.mcchaicxwdcfnbbisdmn.supabase.co:5432/postgres

# ----- Redis Cache -----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# Optional: full Redis URL overrides the above fields
# REDIS_URL=redis://127.0.0.1:6379

# ----- Google Gemini AI -----
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ----- YouTube Data API v3 -----
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here
YOUTUBE_API_BASE_URL=https://www.googleapis.com/youtube/v3

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ----- Logging -----
LOG_LEVEL=info
LOG_DIR=logs
